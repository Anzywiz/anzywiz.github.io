<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AboutYou DE · Product Dataset — Reinox Web Scrapers</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0b0c0f;
    --surface: #111318;
    --surface2: #181b22;
    --border: rgba(255,255,255,0.07);
    --text: #e8eaf0;
    --muted: #6b7280;
    --accent: #4fffb0;
    --accent-dim: rgba(79,255,176,0.12);
    --accent-dim2: rgba(79,255,176,0.06);
    --amber: #f59e0b;
    --red: #ef4444;
    --green: #4fffb0;
    --gray: #4b5563;
    --radius: 10px;
    --font-mono: 'DM Mono', monospace;
    --font-display: 'Syne', sans-serif;
    --font-body: 'Cormorant Garamond', serif;
  }
  body.light {
    --bg: #f5f5f0;
    --surface: #fffffe;
    --surface2: #f0f0eb;
    --border: rgba(0,0,0,0.09);
    --text: #111318;
    --muted: #6b7280;
    --accent: #0a7c4e;
    --accent-dim: rgba(10,124,78,0.1);
    --accent-dim2: rgba(10,124,78,0.05);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.7;
    transition: background 0.3s, color 0.3s;
  }

  /* NAV */
  nav {
    position: sticky; top: 0; z-index: 200;
    height: 52px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 32px;
    background: var(--bg);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-brand { font-family: var(--font-mono); font-size: 12px; color: var(--muted); }
  .nav-brand a { color: var(--accent); text-decoration: none; font-weight: 500; }
  .nav-brand a:hover { opacity: 0.8; }
  .nav-right { display: flex; align-items: center; gap: 20px; }
  .back-link { font-family: var(--font-mono); font-size: 11px; color: var(--muted); text-decoration: none; }
  .back-link:hover { color: var(--accent); }
  .theme-btn {
    background: none; border: 1px solid var(--border); color: var(--muted);
    font-size: 11px; font-family: var(--font-mono); cursor: pointer;
    padding: 4px 10px; border-radius: 4px;
  }
  .theme-btn:hover { color: var(--accent); border-color: var(--accent); }

  /* LAYOUT */
  .container { max-width: 960px; margin: 0 auto; padding: 0 32px; }
  section { padding: 64px 0; border-bottom: 1px solid var(--border); }
  section:last-of-type { border-bottom: none; }

  /* HERO */
  .hero { padding: 80px 0 64px; }
  .hero-eyebrow {
    font-family: var(--font-mono); font-size: 11px; color: var(--accent);
    letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 20px;
  }
  .hero h1 {
    font-family: var(--font-display); font-size: clamp(36px, 6vw, 68px);
    font-weight: 800; line-height: 1.05; letter-spacing: -0.02em;
    margin-bottom: 24px;
  }
  .hero h1 em { font-style: italic; color: var(--accent); }
  .hero-desc {
    font-family: var(--font-body); font-size: 20px; color: var(--muted);
    max-width: 640px; line-height: 1.6; margin-bottom: 40px;
  }
  .badge-row { display: flex; flex-wrap: wrap; gap: 10px; }
  .badge {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font-mono); font-size: 11px;
    border: 1px solid var(--border); border-radius: 20px;
    padding: 5px 14px; color: var(--muted);
    background: var(--surface);
  }
  .badge .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }
  .badge.active { border-color: var(--accent); color: var(--accent); }

  /* SECTION HEADERS */
  .section-label {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--accent); margin-bottom: 8px;
  }
  h2 {
    font-family: var(--font-display); font-size: 32px; font-weight: 700;
    margin-bottom: 32px; letter-spacing: -0.01em;
  }

  /* GRANULARITY */
  .gran-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .gran-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 28px;
  }
  .gran-card.highlight { border-color: var(--accent); background: var(--accent-dim2); }
  .gran-card h3 { font-family: var(--font-display); font-size: 18px; font-weight: 600; margin-bottom: 12px; }
  .gran-card .label { font-family: var(--font-mono); font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px; }
  .gran-card ul { list-style: none; }
  .gran-card ul li { font-size: 15px; color: var(--muted); padding: 5px 0; border-bottom: 1px solid var(--border); }
  .gran-card ul li:last-child { border-bottom: none; }
  .gran-card ul li span { color: var(--text); }
  .miss { color: var(--red) !important; }
  .hit { color: var(--accent) !important; }

  /* STATS */
  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .stat-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 28px 24px;
  }
  .stat-card .num {
    font-family: var(--font-display); font-size: 38px; font-weight: 700;
    color: var(--accent); line-height: 1; margin-bottom: 8px;
  }
  .stat-card .label { font-family: var(--font-mono); font-size: 11px; color: var(--muted); }

  /* TABLE */
  .sample-wrap { overflow-x: auto; border-radius: var(--radius); border: 1px solid var(--border); }
  table { width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 12px; }
  thead { background: var(--surface2); }
  th { padding: 12px 16px; text-align: left; color: var(--muted); font-weight: 400; white-space: nowrap; border-bottom: 1px solid var(--border); }
  td { padding: 11px 16px; border-bottom: 1px solid var(--border); color: var(--text); white-space: nowrap; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--surface2); }
  .truncate { max-width: 180px; overflow: hidden; text-overflow: ellipsis; }

  /* FILL RATES */
  .fill-list { display: flex; flex-direction: column; gap: 10px; }
  .fill-row { display: grid; grid-template-columns: 200px 1fr 60px; align-items: center; gap: 16px; }
  .fill-name { font-family: var(--font-mono); font-size: 12px; color: var(--text); }
  .fill-bar-bg { background: var(--surface2); border-radius: 4px; height: 6px; overflow: hidden; }
  .fill-bar { height: 100%; border-radius: 4px; background: var(--accent); transition: width 0.6s ease; }
  .fill-bar.warn { background: var(--amber); }
  .fill-bar.low { background: var(--red); }
  .fill-pct { font-family: var(--font-mono); font-size: 11px; color: var(--muted); text-align: right; }

  /* FIELD STATUS */
  .fields-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; }
  .field-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px; background: var(--surface); border: 1px solid var(--border);
    border-radius: 6px; font-family: var(--font-mono); font-size: 12px;
  }
  .field-name { color: var(--text); }
  .field-status { display: flex; align-items: center; gap: 6px; }
  .status-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .status-dot.filled { background: var(--green); }
  .status-dot.partial { background: var(--amber); }
  .status-dot.not-collected { background: var(--gray); }
  .status-dot.na { background: var(--gray); opacity: 0.5; }
  .status-label { font-size: 10px; color: var(--muted); }

  /* IMPROVEMENTS */
  .impr-list { display: flex; flex-direction: column; gap: 16px; }
  .impr-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 20px 24px;
    display: flex; justify-content: space-between; align-items: flex-start; gap: 16px;
  }
  .impr-info h4 { font-family: var(--font-display); font-size: 17px; font-weight: 600; margin-bottom: 4px; }
  .impr-info p { font-size: 14px; color: var(--muted); }
  .impr-tag {
    font-family: var(--font-mono); font-size: 10px; padding: 4px 12px;
    border-radius: 20px; white-space: nowrap; flex-shrink: 0;
    border: 1px solid; letter-spacing: 0.05em;
  }
  .impr-tag.easy { color: var(--green); border-color: var(--green); }
  .impr-tag.medium { color: var(--amber); border-color: var(--amber); }
  .impr-tag.hard { color: var(--red); border-color: var(--red); }
  .note-box {
    margin-top: 24px; padding: 18px 24px; background: var(--accent-dim2);
    border: 1px solid rgba(79,255,176,0.15); border-radius: var(--radius);
    font-size: 15px; color: var(--muted);
  }
  .note-box strong { color: var(--text); }

  /* DELIVERY */
  .code-block {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 24px; overflow-x: auto;
    font-family: var(--font-mono); font-size: 13px; color: var(--muted);
    line-height: 1.8;
  }
  .code-block .accent { color: var(--accent); }
  .code-block .key { color: #818cf8; }

  /* CONTACT */
  .contact-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 36px; display: flex;
    justify-content: space-between; align-items: center; gap: 24px;
    flex-wrap: wrap;
  }
  .contact-name { font-family: var(--font-display); font-size: 28px; font-weight: 700; }
  .contact-meta { font-family: var(--font-mono); font-size: 12px; color: var(--muted); margin-top: 4px; }
  .tg-btn {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--accent); color: #0b0c0f;
    font-family: var(--font-mono); font-size: 13px; font-weight: 500;
    padding: 12px 24px; border-radius: 6px; text-decoration: none;
    transition: opacity 0.2s;
  }
  .tg-btn:hover { opacity: 0.85; }

  /* CATS */
  .cats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .cat-pill {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 6px; padding: 12px 16px; font-family: var(--font-mono); font-size: 12px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .cat-pill .pct { color: var(--accent); }

  @media (max-width: 680px) {
    .gran-grid, .stats-grid, .fields-grid, .cats-grid { grid-template-columns: 1fr; }
    nav { padding: 0 16px; }
    .container { padding: 0 16px; }
    .fill-row { grid-template-columns: 140px 1fr 50px; }
  }
</style>
</head>
